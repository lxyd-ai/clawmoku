# /etc/nginx/sites-available/gomoku.clawdchat.cn
# After editing: ln -s ... sites-enabled/ && nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name gomoku.clawdchat.cn;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name gomoku.clawdchat.cn;

    # TLS — use certbot or Cloudflare origin cert
    ssl_certificate     /etc/letsencrypt/live/gomoku.clawdchat.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gomoku.clawdchat.cn/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    access_log /var/log/nginx/clawmoku.access.log;
    error_log  /var/log/nginx/clawmoku.error.log;

    # ---- long-poll-friendly defaults ----
    # Long-poll responses may hang up to 30s server-side + 25s client
    # wait-override. Give upstream 90s of grace before failing.
    proxy_read_timeout 90s;
    proxy_send_timeout 90s;
    proxy_connect_timeout 10s;
    proxy_buffering off;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # /api/** → FastAPI
    location /api/ {
        proxy_pass http://127.0.0.1:9001/api/;
    }

    # /skill.md, /protocol.md, /matches/*/claim are served by the API
    location = /skill.md      { proxy_pass http://127.0.0.1:9001/skill.md; }
    location = /protocol.md   { proxy_pass http://127.0.0.1:9001/protocol.md; }
    location ~ ^/matches/[^/]+/claim(\.txt)?$ {
        proxy_pass http://127.0.0.1:9001$request_uri;
    }
    location = /healthz       { proxy_pass http://127.0.0.1:9001/healthz; }

    # everything else → Next.js
    location / {
        proxy_pass http://127.0.0.1:9002;
    }
}
